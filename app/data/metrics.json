  "metrics": [
    {
      "id": "H1_M1",
      "name": "Отсутствие индикаторов загрузки",
      "category": "H1_Visibility",
      "type": "boolean",
      "weight": 0.8,
      "config": {
        "operation": "exists",
        "selectors": [".spinner", ".loading", "[role=progressbar]"],
        "text_contains": ["loading"],
        "description": "Проверяет наличие индикаторов загрузки"
      }
    },
    {
      "id": "H1_M2",
      "name": "Отсутствие системных уведомлений",
      "category": "H1_Visibility",
      "type": "boolean",
      "weight": 0.7,
      "config": {
        "operation": "exists",
        "selectors": [".toast", ".alert", "[role=status]"],
        "description": "Проверяет наличие системных уведомлений"
      }
    },
    {
      "id": "H1_M3",
      "name": "Обратная связь на действия",
      "category": "H1_Visibility",
      "type": "ratio",
      "weight": 0.9,
      "config": {
        "operation": "ratio",
        "numerator": {
          "selector": "*",
          "condition": "has_feedback"
        },
        "denominator": {
          "selector": "button, input, form"
        },
        "description": "Процент интерактивных элементов с обратной связью"
      }
    },
    {
